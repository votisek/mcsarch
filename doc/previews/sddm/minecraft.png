    <style>
      .user-mention[href$="/votisek"] {
        color: var(--color-user-mention-fg);
        background-color: var(--bgColor-attention-muted, var(--color-attention-subtle));
        border-radius: 2px;
        margin-left: -2px;
        margin-right: -2px;
      }
      .user-mention[href$="/votisek"]:before,
      .user-mention[href$="/votisek"]:after {
        content: '';
        display: inline-block;
        width: 2px;
      }
    </style>


